# Postgres connection string (Supabase: use the "Connection Pooling" URI for DATABASE_URL
# and the direct connection URI for DIRECT_URL)
DATABASE_URL="postgresql://user:password@host:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Used by prisma/seed.ts to create the first Super Admin account
SEED_ADMIN_NAME="Reynald"
SEED_ADMIN_EMAIL="admin@yourcompany.co.nz"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# A secret you make up yourself (any random string). Protects the one-time
# /api/setup/seed-admin bootstrap URL used to create the first Super Admin
# without needing to run any command locally.
SETUP_SECRET="make-up-another-random-string"
